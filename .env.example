# RemovePII environment variables. Copy to .env and fill in.

# Path to the client license-key database (JSON).
# Default: clients.json in the working directory.
REMOVEPII_CLIENTS_FILE=clients.json

# Local LLM endpoint (OpenAI-compatible). Defaults to Ollama's port.
# LM Studio equivalent: http://localhost:1234/v1
LLM_BASE_URL=http://localhost:11434/v1

# Ignored by local LLM servers but required by the OpenAI SDK.
LLM_API_KEY=local

# Model name. Ollama llama3.1:8b is the recommended default — smaller 3B
# models (e.g. llama3.2:3b) tend to echo input verbatim on CVs rather than
# following the redaction rules. LM Studio: whatever you loaded.
LLM_MODEL=llama3.1:8b

# Paths for the CSV billing/feedback logs (no document content).
USAGE_LEDGER_PATH=usage_ledger.csv
FEEDBACK_LOG_PATH=feedback_log.csv

# Backend feedback endpoint used by the frontend's feedback form.
FEEDBACK_URL=http://127.0.0.1:8000/v1/feedback
